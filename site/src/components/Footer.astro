---
const techStack = [
  { name: 'Tauri', url: 'https://v2.tauri.app/', img: './assets/tauri.webp' },
  { name: 'React', url: 'https://react.dev/', img: './assets/react.webp' },
  { name: 'MobX', url: 'https://mobx.js.org/', img: './assets/mobx.webp' },
  { name: 'MUI', url: 'https://mui.com/', img: './assets/mui.webp' },
  { name: 'Tokio', url: 'https://tokio.rs/', img: './assets/tokio.webp' },
  { name: 'V8', url: 'https://v8.dev/', img: './assets/v8.webp' },
  { name: 'Rust', url: 'https://www.rust-lang.org/', img: './assets/rust.webp' },
  { name: 'TypeScript', url: 'https://www.typescriptlang.org/', img: './assets/typescript.webp' },
];
---

<footer class="footer">
  <div class="container footer-inner">
    <h2 class="footer-title">Built With</h2>
    <div class="tech-grid">
      {techStack.map(tech => (
        <a href={tech.url} target="_blank" class="tech-item" title={tech.name}>
          <img src={tech.img} alt={tech.name} class="tech-icon" />
          <span class="tech-name">{tech.name}</span>
        </a>
      ))}
    </div>
    <p class="footer-note">...and lots of other generous work from the open-source community</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 0 2rem;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .footer-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    padding: 0.75rem;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  .tech-item:hover {
    background: var(--color-surface);
    text-decoration: none;
  }

  .tech-icon {
    height: 40px;
    width: auto;
  }

  .tech-name {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    font-weight: 500;
  }

  .footer-note {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin: 0;
  }

  @media screen and (max-width: 480px) {
    .tech-grid {
      gap: 0.75rem;
    }
    .tech-icon {
      height: 32px;
    }
  }
</style>
